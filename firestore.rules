rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict Path-Based Ownership model. All data is logically
     * and physically partitioned by the User's unique identifier (UID). This ensures 
     * complete data isolation between users.
     *
     * DATA STRUCTURE
     * The hierarchy follows a flat, user-centric pattern: /users/{userId}/{collection}/{documentId}.
     * There are no global or shared collections; every piece of data (products, configs, 
     * imports, etc.) belongs to exactly one user.
     *
     * KEY SECURITY DECISIONS
     * 1. Path-Based Authorization: We rely on the {userId} wildcard in the path to verify
     *    ownership, making security checks extremely fast and cost-effective.
     * 2. Strict User Isolation: No user can read or write data in another user's path.
     * 3. Resource Verification: Updates and deletes are only permitted if the 
     *    document already exists and belongs to the requester.
     * 4. Prototyping Flexibility: While authorization is strictly enforced via UIDs, 
     *    the internal data structure of products and imports is kept flexible to 
     *    support rapid iteration.
     *
     * DENORMALIZATION FOR AUTHORIZATION
     * By nesting all collections under the /users/{userId} path, the owner's identity 
     * is denormalized into the document's path. This allows rules to perform 
     * O(1) authorization checks without additional database lookups.
     */

    // --- Helper Functions ---

    /** 
     * @description Checks if the user is authenticated with Firebase Auth.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user's UID matches the provided userId from the path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Combines ownership check with a check that the document exists. 
     * Used for state-changing operations (update/delete).
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Rules ---

    /**
     * @description Rules for the user's root document.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches userId.
     * @deny (create) if auth.uid does not match userId.
     * @principle Self-Creation: Users can only create their own root profile document.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Company-specific configurations and preferences.
       * @path /users/{userId}/companyConfiguration/{configId}
       * @allow (update) if user owns the path and document exists.
       * @deny (update) if trying to change the document's internal ID.
       * @principle Relational Integrity: Ensures internal ID matches the document path.
       */
      match /companyConfiguration/{configId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && (request.resource.data.id == configId);
        allow update: if isExistingOwner(userId) && (request.resource.data.id == resource.data.id);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Product data, metrics, and classification.
       * @path /users/{userId}/products/{productId}
       * @allow (list) if request.auth.uid matches the path's userId.
       * @deny (get) if requesting a product in another user's path.
       * @principle Ownership: Only the owning user can manage their product inventory.
       */
      match /products/{productId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && (request.resource.data.id == productId);
        allow update: if isExistingOwner(userId) && (request.resource.data.id == resource.data.id);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description API credentials and status for marketplace integrations.
       * @path /users/{userId}/integrationSettings/{settingId}
       * @allow (create) if user owns the path.
       * @deny (read) if user is not the owner (protects sensitive tokens).
       * @principle Verified Identity: Relies on Firebase Auth to protect sensitive integration tokens.
       */
      match /integrationSettings/{settingId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && (request.resource.data.id == settingId);
        allow update: if isExistingOwner(userId) && (request.resource.data.id == resource.data.id);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Saved report configurations for reuse.
       * @path /users/{userId}/reportTemplates/{templateId}
       * @allow (get) if user owns the path.
       * @deny (create) if userId in path is not the authenticated user.
       * @principle Path-Based Authorization: Context is derived entirely from the URL segment.
       */
      match /reportTemplates/{templateId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && (request.resource.data.id == templateId);
        allow update: if isExistingOwner(userId) && (request.resource.data.id == resource.data.id);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description History and metadata of data import operations.
       * @path /users/{userId}/dataImports/{importId}
       * @allow (list) if isOwner(userId).
       * @deny (update) if document does not exist.
       * @principle Robustness: Verifies resource existence before permitting modifications.
       */
      match /dataImports/{importId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && (request.resource.data.id == importId);
        allow update: if isExistingOwner(userId) && (request.resource.data.id == resource.data.id);
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}